{
  "name": "seo-content-graph-agent",
  "version": "1.0.0",
  "description": "Autonomous state-machine SEO content graph agent for semantic clustering and internal link optimization",
  "type": "module",
  "main": "dist/agent.js",
  "bin": {
    "seo-graph": "dist/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:cli",
    "build:cli": "tsc -p tsconfig.cli.json",
    "preview": "vite preview",
    "cli": "node dist/cli.js",
    "smoke": "node dist/cli.js analyze --threshold 0.8",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "seo",
    "internal-linking",
    "content-graph",
    "ai-agent",
    "vector-embeddings",
    "pagerank"
  ],
  "author": "Bilal Sevinc",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "netlify-cli": "^26.2.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.6",
    "vitest": "^1.4.0"
  }
}
